@startuml UseCaseDiagram
left to right direction
scale 2400 width

skinparam backgroundColor White
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam nodesep 40
skinparam ranksep 120

skinparam actor {
    BackgroundColor White
    BorderColor Black
    FontSize 13
    FontStyle bold
}

skinparam usecase {
    BackgroundColor White
    BorderColor Black
    FontSize 12
    BorderThickness 1.5
}

skinparam rectangle {
    BackgroundColor #EEEEEE
    BorderColor Black
    BorderThickness 2
    FontSize 12
    FontColor #333333
    FontStyle bold
}

skinparam ArrowColor Black
skinparam ArrowThickness 1
skinparam ArrowFontSize 11

actor "User"             as user
actor "Facebook\nServers" as fb <<external>>

rectangle "Facebook WinForms App" {

    usecase "View Profile Info"              as UC4
    usecase "View Albums List"               as UC5

    usecase "Browse Friends"                 as UC6
    usecase "Search Friends by Name"         as UC7
    usecase "View Friend Details"            as UC8

    usecase "Compose and Post Status"        as UC9
    usecase "View Recent Posts Feed"         as UC10

    usecase "Analyze Photos (Strategy)"      as UC11
    usecase "Find Most Liked Photo"          as UC12
    usecase "Find Most Commented Photo"      as UC13
    usecase "Find Most Tagged Photo"         as UC14
    usecase "Find Oldest Photo"              as UC15
    usecase "Find Newest Photo"              as UC16

    usecase "Find Album With Most Photos"    as UC17
    usecase "Count Albums"                   as UC18

    usecase "Load Albums into Grid"          as UC19
    usecase "Inspect Album Thumbnails"       as UC20
    usecase "Upload Photo to Album"          as UC21
}

' User initiates all actions
user -- UC4
user -- UC5
user -- UC6
user -- UC9
user -- UC10
user -- UC11
user -- UC17
user -- UC18
user -- UC19

' Photo Strategy sub-types
UC11 .> UC12 : <<extend>>
UC11 .> UC13 : <<extend>>
UC11 .> UC14 : <<extend>>
UC11 .> UC15 : <<extend>>
UC11 .> UC16 : <<extend>>

' Friends sub-flows
UC7 .> UC6 : <<include>>
UC8 .> UC6 : <<include>>

' Album Analyst sub-flows
UC19 .> UC20 : <<extend>>
UC19 .> UC21 : <<extend>>

' Facebook Servers participate in all data-access use cases
fb -- UC4
fb -- UC5
fb -- UC6
fb -- UC9
fb -- UC10
fb -- UC11
fb -- UC17
fb -- UC18
fb -- UC19
fb -- UC21

@enduml
